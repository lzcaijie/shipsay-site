    <?php if (Ss::use_js() && !$isSearchEngine) : ?>
       setTimeout(function() {
           $.ajax({
               type: "post",
               url: "/api/reader_js.php",
               data: {
                   articleid: '<?= $articleid ?>',
                   chapterid: '<?= $chapterid ?>',
                   pid: '<?= $now_pid ?>'
               },
               success: function(data) {
                   $('#article').html(data);
               },
               error: function() {
                   $('#article').html('<div class="error-text">加载失败，请刷新重试</div>');
               }
           });
       }, 200);
   <?php endif ?>
 
